# Mandatory for Windows local + Linux M3 sync via Mutagen.
# Without this, every text file is a Mutagen conflict (CRLF vs LF) and
# bash shebangs break on M3 because \r becomes part of the interpreter path.
# Pairs with: git config core.autocrlf input (set repo-local).

* text=auto eol=lf

# Explicit LF for files where line endings affect runtime behavior:
*.sh    text eol=lf
*.slurm text eol=lf
*.py    text eol=lf
*.qmd   text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.toml  text eol=lf

# Explicit binary so they never get normalized:
*.png   binary
*.jpg   binary
*.jpeg  binary
*.pdf   binary
*.nc    binary
*.npy   binary
*.npz   binary
*.parquet binary
*.feather binary
*.h5    binary
*.hdf5  binary
*.zip   binary
*.gz    binary
*.tar   binary
*.tgz   binary
*.nii   binary
*.nii.gz binary
